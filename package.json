{
  "name": "uauth-nextjs-client",
  "version": "1.0.5",
  "description": "Custom NextAuth (Auth.js) provider for UAuth OIDC",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "nextauth",
    "auth.js",
    "uauth",
    "oidc",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "next-auth": ">=5.0.0-beta.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}